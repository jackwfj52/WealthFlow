<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.jack.wealthflow.mapper.AssetCategoryMapper">

    <select id="findAll"
            resultType="org.jack.wealthflow.model.AssetCategory">
        SELECT
        id,
        name,
        created_date AS createdDate
        FROM asset_category
        ORDER BY id
    </select>

</mapper>